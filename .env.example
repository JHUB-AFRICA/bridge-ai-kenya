# ================================================================
# BRIDGE-AI Kenya - Environment Variables Template (JSON Version)
# ================================================================
# Copy this file to .env and update values for your environment
# No database required - uses JSON file storage.
# ================================================================

# ================================================================
# FLASK APPLICATION
# ================================================================

FLASK_APP=run.py
FLASK_ENV=development             # development | production | testing
FLASK_DEBUG=1
SECRET_KEY=your-super-secret-key-change-this-in-production

# ================================================================
# JSON DATA STORAGE (No Database!)
# ================================================================

# Path to JSON data files (relative to app root)
DATA_FOLDER=app/data

# ================================================================
# ADMIN USER (for initial seeding)
# ================================================================

ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-admin-password-change-me
ADMIN_EMAIL=admin@jkuat.ac.ke

# ================================================================
# EMAIL CONFIGURATION (for contact form)
# ================================================================

MAIL_SUPPRESS_SEND=True            # Set to False in production
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@bridge-ai-kenya.com
MAIL_RECIPIENT=info@jkuat.ac.ke    # Where contact forms go

# ================================================================
# FILE UPLOADS
# ================================================================

MAX_CONTENT_LENGTH=16777216        # 16MB max upload size
UPLOAD_FOLDER=app/static/images/uploads

# ================================================================
# CSRF PROTECTION
# ================================================================

CSRF_ENABLED=True
WTF_CSRF_SECRET_KEY=csrf-secret-key-change-this-in-production

# ================================================================
# SECURITY (Production Only)
# ================================================================

SESSION_COOKIE_SECURE=False        # Set to True in production (HTTPS only)
REMEMBER_COOKIE_SECURE=False       # Set to True in production (HTTPS only)
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# ================================================================
# ANALYTICS (optional)
# ================================================================

# ANALYTICS_ID=UA-XXXXX-X

# ================================================================
# LOGGING
# ================================================================

LOG_LEVEL=INFO
LOG_FILE=logs/app.log